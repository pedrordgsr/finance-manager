generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Direction {
  IN
  OUT
}

enum CategoryKind {
  IN
  OUT
  BOTH
}

enum AccountType {
  CASH
  BANK
  CREDIT_CARD
  INVESTMENT
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categories     Category[]
  paymentMethods PaymentMethod[]
  accounts       Account[]
  transactions   Transaction[]
  budgets        Budget[]
}

model Category {
  id        Int          @id @default(autoincrement())
  name      String
  kind      CategoryKind @default(BOTH)
  createdAt DateTime     @default(now())
  userId    Int
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name])
  @@index([userId])
}

model PaymentMethod {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId])
}

model Account {
  id        Int         @id @default(autoincrement())
  name      String
  type      AccountType @default(BANK)
  createdAt DateTime    @default(now())
  userId    Int
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id             Int       @id @default(autoincrement())

  direction      Direction
  amountCents    Int       // evita float: R$ 12,34 => 1234

  issueDate      DateTime
  settlementDate DateTime?

  description    String
  notes          String?

  categoryId     Int
  category       Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  paymentMethodId Int?
  paymentMethod   PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  accountId      Int?
  account        Account?  @relation(fields: [accountId], references: [id], onDelete: SetNull)

  userId         Int
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([issueDate])
  @@index([settlementDate])
  @@index([categoryId])
  @@index([direction])
  @@index([userId])
}

model Budget {
  id          Int      @id @default(autoincrement())
  amountCents Int
  month       Int      // 0-11
  year        Int
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, categoryId, month, year])
  @@index([userId])
}
